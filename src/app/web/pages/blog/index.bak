import React, { useEffect, useState } from "react";
import api from "app/web/api";
import { Row, Col, Typography, Card, Divider } from "antd";
import defaultImg from "image/foods/17.png";
import { Link } from "react-router-dom";
import routeURL from "config/routeURL";
import config from "config";
import avatar from "image/logo.png";
import moment from "moment";
import { handleError } from 'services/util';
import "./index.css";

const { Meta } = Card;

function Blogs() {
  const [blogs, setBlogs] = useState([]);
  const [spinning, setSpinning] = useState(false);
  useEffect(() => {
    setSpinning(true);
    api.blog
      .read_active()
      .then(({ data }) => setBlogs(data))
      .catch(handleError)
      .finally(() => setSpinning(false));
  }, []);
  return (
    <Row style={{ marginTop: 80 }}>
      {blogs.map((item, index) => {
      return (
        <Link
          to={routeURL.web.blog_detail(item?._id)}
          className="product-image"
          style={{
            borderRadius: "unset",
          }}
        >
          <Col className="blog-card" lg="8" md="12" sm="24" xm="24">
            <Row>
              <img
                style={{
                    height: "250px",
                    width: "350px",
                    objectFit: "cover",
                    borderTopLeftRadius: "10px",
                    borderTopRightRadius: "10px",
                  }}
                  alt="example"
                  src={
                    item.images && item.images.length > 0
                      ? config.getImageHost(item?.images[0])
                      : defaultImg
                  }
                />
              </Row>
              <Col style={{ padding: "20px 30px" }}>
                <Row>
                  <p>{moment(item.createdDateTime).format("ll")}</p>
                </Row>
                <Row>{item.title}</Row>
                <Row>{item.metaDescription.description}</Row>
                <Divider />
                <Row>Author: {item.author}</Row>
              </Col>
            </Col>
          </Link>
        );
      })}
      F
    </Row>
  );
}

export default Blogs;
